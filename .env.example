# Copy to .env.local and fill in. Never commit real secrets.

# PostgreSQL — EITHER a single URL…
# (if the password has special characters, percent-encode them: @ → %40, etc.)
DATABASE_URL=postgresql://user:password@localhost:5432/senaycreatives
# …OR discrete fields (no encoding needed — recommended on cPanel). Set these
# and leave DATABASE_URL unset:
# PGHOST=localhost
# PGPORT=5432
# PGUSER=cpaneluser_dbuser
# PGPASSWORD=the-raw-password-no-encoding-needed
# PGDATABASE=cpaneluser_dbname

# SMTP for submission notifications (shared host provides these)
SMTP_HOST=smtp.yourhost.com
SMTP_PORT=587
SMTP_USER=hello@senaycreatives.com
SMTP_PASS=changeme
SMTP_FROM=SenayCreatives <hello@senaycreatives.com>
NOTIFY_TO=hello@senaycreatives.com

# CV uploads — directory OUTSIDE the deploy dir so redeploys don't wipe them.
# On the shared host this is typically something like /home/USER/uploads
UPLOAD_DIR=./.uploads
MAX_UPLOAD_MB=5

# Manager backend (/admin) — DB-backed sessions (Phase 2). No env credentials:
# seed accounts with the create-user script (passwords hashed with scrypt).
#   pnpm create-user you@senaycreatives.com "a-long-password" "Your Name" admin
# Sessions live in the `sessions` table; the cookie is `secure` in production,
# so serve the admin over HTTPS.

# Analytics (optional) — set ONE to turn it on; leave unset for no tracking.
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=senaycreatives.com
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
